{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "ESNext"],
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "**/dist/**"]
}
